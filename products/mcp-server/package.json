{
  "name": "@ai-native-framework/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP adapter for the AI-native framework: projects interfaces/interfaces.yaml workflow_repository operations to third-party agent clients.",
  "scripts": {
    "generate": "node ../../scripts/generate-mcp-tools.mjs",
    "start": "npm run generate && tsx src/index.ts",
    "build": "npm run generate && node build.mjs",
    "install:claude-desktop": "npm run build && node install-claude-desktop.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.105.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
