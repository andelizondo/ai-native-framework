NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@o<org>.ingest.sentry.io/<project-id>
SENTRY_DSN=https://<public-key>@o<org>.ingest.sentry.io/<project-id>

# Auth provider config
# Comma-separated enabled providers for the dashboard auth UI.
# Phase 1 default is magic_link. Add google later when the provider is configured.
NEXT_PUBLIC_AUTH_PROVIDERS=magic_link
# Supabase runtime client config.
# Per-environment scoping (set in Vercel → Settings → Environment Variables):
#   - Production env: values for the PRODUCTION Supabase project
#   - Preview env:    values for the STAGING Supabase project
#   - Development env: values for the STAGING project (or your local stack via `supabase start`)
# See `ai/playbooks/environment-separation.md` Database tier section.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# OPTIONAL — server-only admin key for elevated operations (bypasses RLS).
# Leave unset unless server code explicitly needs admin access. NEVER expose
# in any NEXT_PUBLIC_* var. If used, scope per-environment in Vercel like the
# pair above.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional E2E-only bypass for authenticated browser tests.
# Configure the same secret in the app runtime and Playwright environment.
AUTH_E2E_BYPASS_SECRET=

# Optional E2E-only Supabase session minting. When the bypass cookie above is
# valid AND `SUPABASE_SERVICE_ROLE_KEY` is set, the server uses the admin API
# to mint a real session for the bypass user (lookup by email) and overlays it
# as the `sb-<project-ref>-auth-token` cookie. This is what lets Playwright
# specs (and local manual testing) hit RLS-protected DB calls as the bypass
# user without going through the magic-link UI flow. Sessions are cached in
# server memory and refreshed automatically before expiry.

# Recommended runtime metadata for meaningful Sentry filtering and regressions
# Release defaults to the canonical repo release (`version.txt`) on production builds
# and falls back to commit SHA elsewhere. Set these only to override that behavior.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Override only — leave empty to use canonical release resolution (version.txt on production, commit SHA elsewhere).
NEXT_PUBLIC_SENTRY_RELEASE=
# Opt-in only: enables Sentry sendDefaultPii (PII-class request data). Default in code is off unless "true".
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENVIRONMENT=development
# Optional: server stack local-variable capture for debugging (off unless "true"; can expose secrets).
SENTRY_INCLUDE_LOCAL_VARIABLES=false
# Override only — leave empty to use canonical release resolution (version.txt on production, commit SHA elsewhere).
SENTRY_RELEASE=

# Optional global release override used by Sentry and PostHog when set.
NEXT_PUBLIC_APP_RELEASE=

# Optional: source map upload during next build
SENTRY_AUTH_TOKEN=sntrys_<token>
SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>

# PostHog — EU region
# Project token is public (NEXT_PUBLIC prefix is intentional and correct)
# Server-side SDK host — used by lib/analytics/posthog-server.ts; must always be the EU endpoint.
# Browser client uses /ingest reverse proxy (next.config.ts) — not affected by this var.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# phc_... from PostHog project settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
