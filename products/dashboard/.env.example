NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@o<org>.ingest.sentry.io/<project-id>
SENTRY_DSN=https://<public-key>@o<org>.ingest.sentry.io/<project-id>

# Recommended runtime metadata for meaningful Sentry filtering and regressions
# Release defaults to the canonical repo release (`version.txt`) on production builds
# and falls back to commit SHA elsewhere. Set these only to override that behavior.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=local-dev
# Opt-in only: enables Sentry sendDefaultPii (PII-class request data). Default in code is off unless "true".
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENVIRONMENT=development
# Optional: server stack local-variable capture for debugging (off unless "true"; can expose secrets).
SENTRY_INCLUDE_LOCAL_VARIABLES=false
SENTRY_RELEASE=local-dev

# Optional global release override used by Sentry and PostHog when set.
NEXT_PUBLIC_APP_RELEASE=

# Optional: source map upload during next build
SENTRY_AUTH_TOKEN=sntrys_<token>
SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>

# PostHog — EU region
# Project token is public (NEXT_PUBLIC prefix is intentional and correct)
# Server-side SDK host — used by lib/analytics/posthog-server.ts; must always be the EU endpoint.
# Browser client uses /ingest reverse proxy (next.config.ts) — not affected by this var.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# phc_... from PostHog project settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
